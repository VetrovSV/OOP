    {
      "id": "IrpSXgNQ037MLBmpTZKEM",
      "type": "text",
      "x": -1082.798881879006,
      "y": 424.85508012620716,
      "width": 757.6025129872884,
      "height": 367.20000000000005,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "fnogt99ID36b2uOg0aCvV",
      "index": "aV",
      "roundness": null,
      "seed": 1560400267,
      "version": 660,
      "versionNonce": 1239818405,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1763135455682,
      "link": null,
      "locked": false,
      "text": "○ GCC (GNU Compiler Collection)\nКомплексный набор компиляторов для языков C, C++, Fortran и др., широко используется в Linux и\nUnix-системах. Обеспечивает высокую оптимизацию и совместимость со стандартами.\nСкачать: https://gcc.gnu.org\n\n○ Clang \\ LLVM\nМодульный компилятор на базе LLVM, известен быстрой компиляцией и подробными\nдиагностическими сообщениями об ошибках. Активно развивается в экосистеме macOS и Linux.\nКомпилирует C в промежуточное представление (LLVM IR) похожее на машинный код, но\nнезависимое от аппаратной системы. Далее код из IR компилирутеся в специфичный для\nплатформы (например x86-64) код.\nСкачать: https://clang.llvm.org\n\n○ MSVC (Microsoft Visual C++)\nКомпилятор C/C++ в составе среды разработки Visual Studio для Windows. Предлагает\nинтегрированные отладчик и инструменты профилирования от Microsoft.\nСкачать: https://visualstudio.microsoft.com/downloads/",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "○ GCC (GNU Compiler Collection)\nКомплексный набор компиляторов для языков C, C++, Fortran и др., широко используется в Linux и Unix-системах. Обеспечивает высокую оптимизацию и совместимость со стандартами.\nСкачать: https://gcc.gnu.org\n\n○ Clang \\ LLVM\nМодульный компилятор на базе LLVM, известен быстрой компиляцией и подробными диагностическими сообщениями об ошибках. Активно развивается в экосистеме macOS и Linux.\nКомпилирует C в промежуточное представление (LLVM IR) похожее на машинный код, но независимое от аппаратной системы. Далее код из IR компилирутеся в специфичный для платформы (например x86-64) код.\nСкачать: https://clang.llvm.org\n\n○ MSVC (Microsoft Visual C++)\nКомпилятор C/C++ в составе среды разработки Visual Studio для Windows. Предлагает интегрированные отладчик и инструменты профилирования от Microsoft.\nСкачать: https://visualstudio.microsoft.com/downloads/",
      "autoResize": false,
      "lineHeight": 1.35
    },
    {
      "id": "wqQO-YFKLcr7yuS5WrOgC",
      "type": "text",
      "x": -296.8591708868915,
      "y": 375.88505395446185,
      "width": 243.75064783242397,
      "height": 194.4,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "fnogt99ID36b2uOg0aCvV",
      "index": "aW",
      "roundness": null,
      "seed": 267725189,
      "version": 367,
      "versionNonce": 949647813,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1763136208384,
      "link": null,
      "locked": false,
      "text": "GCC:\ngcc -o myprog myprog.c\n\nClang \\ LLVM:\nclang -o myprog myprog.c\n\nMSVC:\ncl /Fe:myprog.exe myprog.c\n",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "GCC:\ngcc -o myprog myprog.c\n\nClang \\ LLVM:\nclang -o myprog myprog.c\n\nMSVC:\ncl /Fe:myprog.exe myprog.c\n",
      "autoResize": false,
      "lineHeight": 1.35
    },
