    {
      "id": "zTNx8MsFPQZxlgvVMkhxd",
      "type": "text",
      "x": 1201.721561017099,
      "y": 276.6419775382025,
      "width": 757.6025129872884,
      "height": 21.6,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
